# ============================================
# ClickPilot Backend Environment Variables
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB Atlas Connection String Format:
# mongodb+srv://username:password@cluster.mongodb.net/clickpilot
MONGODB_URI=mongodb://localhost:27017/clickpilot

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRE=7d

# CORS Configuration (Optional)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting (requests per 15 minutes)
AUTH_RATE_LIMIT=10
LINK_RATE_LIMIT=20

# API Base URL (for QR code generation)
API_BASE_URL=http://localhost:5000
